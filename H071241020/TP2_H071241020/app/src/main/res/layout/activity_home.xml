<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@android:color/white">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_home"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/nav_bar_home" />

    <LinearLayout
        android:id="@+id/nav_bar_home"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_alignParentBottom="true"
        android:background="#FAFAFA"
        android:elevation="8dp"
        android:orientation="horizontal">
        <Button android:id="@+id/btn_to_home" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:text="Home" android:background="?android:attr/selectableItemBackground"/>
        <Button android:id="@+id/btn_to_post" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:text="Post" android:background="?android:attr/selectableItemBackground"/>
        <Button android:id="@+id/btn_to_profile" android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent" android:text="Profile" android:background="?android:attr/selectableItemBackground"/>
    </LinearLayout>
</RelativeLayout>